# OperonAI Environment Configuration
# Copy this file to .env and fill in the values

# ─── Frontend ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_WEBHOOK_URL=http://localhost:3001/api/webhooks

# ─── Backend Ports ──────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001

# ─── Firebase (optional, for authentication) ────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── OpenAI (for AI nodes) ─────────────────────────────
OPENAI_API_KEY=

# ─── Gmail Integration ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/connections/gmail/callback

# ─── Slack Integration ─────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─── Webhook Configuration ─────────────────────────────
WEBHOOK_BASE_URL=http://localhost:3001/api/webhooks
